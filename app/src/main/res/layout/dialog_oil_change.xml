<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Кога беше последната смяна?"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/car_primary"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvOilDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Дата на смяна: Избери..."
        android:textSize="16sp"
        android:padding="12dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:drawablePadding="8dp"
        app:drawableStartCompat="@drawable/ic_calendar" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Километри при смяната">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etOilMileage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="* Следваща смяна ще бъде изчислена след 10 000 км или 1 година."
        android:textSize="12sp"
        android:textColor="@color/car_accent"
        android:textStyle="italic" />

</LinearLayout>